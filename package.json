{
  "name": "pnpm-pub",
  "version": "1.2.0",
  "description": "Desktop-level local daemon proxy and productivity tool for high-frequency NPM package authors.",
  "keywords": [
    "2fa",
    "daemon",
    "npm",
    "oidc",
    "publish",
    "totp",
    "tray",
    "trusted-publish"
  ],
  "homepage": "https://github.com/Gaubee/pnpm-pub#readme",
  "bugs": {
    "url": "https://github.com/Gaubee/pnpm-pub/issues"
  },
  "license": "MIT",
  "author": "Gaubee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gaubee/pnpm-pub.git"
  },
  "bin": {
    "pnpm-pub": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "gen:icons": "node scripts/gen-icons.mjs",
    "build": "bun run scripts/build/run.ts",
    "dev": "tsx scripts/dev-webui.ts",
    "dev:core": "tsx src/daemon/dev.ts",
    "dev:cli": "bun run src/cli/cli.ts",
    "dev:publish": "bun run src/cli/cli.ts",
    "pub": "node dist/cli.js",
    "release:start": "node dist/cli.js start",
    "release:status": "node dist/cli.js status",
    "release:stop": "node dist/cli.js stop",
    "release:publish": "node dist/cli.js",
    "release:verify": "tsx scripts/release/verify-release.ts",
    "typecheck": "tsc --noEmit",
    "test": "vp test run --project unit && pnpm test:browser",
    "test:watch": "vp test",
    "test:browser": "vp test run --project browser",
    "test:e2e": "vp test run --project e2e",
    "test:e2e:docker": "tsx scripts/run-e2e-docker.ts",
    "clean": "rm -rf dist packages/*/dist webui/build webui/.svelte-kit node_modules/.cache/pnpm-pub-icons",
    "prepare": "vp config"
  },
  "dependencies": {
    "@github/keytar": "^7.0.0",
    "@opentray/ext-webview": "^0.12.0",
    "opentray": "^0.12.0"
  },
  "devDependencies": {
    "@gaubee/node": "^0.4.0",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/server": "1.14.6",
    "@orpc/zod": "1.14.6",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.14",
    "@types/hosted-git-info": "^3.0.5",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^24.0.0",
    "@types/ws": "8.18.1",
    "@types/yargs": "^17.0.33",
    "agent-browser": "0.31.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "hosted-git-info": "^9.0.3",
    "http-proxy": "^1.18.1",
    "jsdom": "^29.1.1",
    "memfs": "^4.17.0",
    "otplib": "^12.0.1",
    "safe-npm-sdk": "^0.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "ws": "8.21.0",
    "yargs": "^17.7.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.22.0"
}
