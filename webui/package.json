    "marked": "^18.0.6",
    "mode-watcher": "^1.0.0",
    "svelte-i18n": "^4.0.1",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/typography": "^0.5.19",
