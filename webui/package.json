{
  "name": "pnpm-pub-webui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "i18n:check": "node --import tsx scripts/i18n-check.mjs",
    "i18n:check:strict": "node --import tsx scripts/i18n-check.mjs --strict",
    "i18n:translate": "node --import tsx scripts/i18n-translate.mjs"
  },
  "dependencies": {
    "@humanspeak/svelte-motion": "^0.7.17",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
